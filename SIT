import React, { useState, useEffect, useRef } from 'react';
import { 
  Users, 
  Utensils, 
  Plus, 
  Trash2, 
  DollarSign, 
  Percent, 
  Receipt, 
  QrCode, 
  Check, 
  RotateCcw,
  Download,
  Upload,
  ChevronDown,
  ChevronUp,
  UserPlus,
  ArrowRight,
